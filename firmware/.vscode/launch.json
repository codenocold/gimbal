{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "JLink",
            "cwd": "${workspaceFolder}",
            "executable": "${workspaceFolder}/${config:make.buildDir}/${config:make.target}.elf",
            "request": "launch",
            "type": "cortex-debug",
            "preLaunchTask": "Build + Load",
            "runToEntryPoint": "main",
            "showDevDebugOutput": "none",
            "servertype": "jlink",
            "serverArgs": [],
            "device": "STM32G431CB",
            "interface": "swd",
            "serialNumber": "",
            "svdFile": "STM32G431.svd",
            "preLaunchCommands": [
                "monitor reset",
                "monitor halt"
            ],
            "liveWatch": {
                "enabled": true,
                "samplesPerSecond": 10
            },
        }
    ]
}